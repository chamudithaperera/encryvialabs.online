{
  "name": "encryvia-labs",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,cyan \"pnpm --filter @encryvia/web dev\" \"pnpm --filter @encryvia/api dev\"",
    "build": "pnpm --filter @encryvia/web build && pnpm --filter @encryvia/api build",
    "start": "concurrently -n web,api -c blue,cyan \"pnpm --filter @encryvia/web start\" \"pnpm --filter @encryvia/api start\"",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "prettier . --write"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.32.0",
    "eslint-config-next": "^15.4.6",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.39.0"
  }
}
